<Window x:Class="OllamaModelManagerByObviousIdea.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ollama Model Manager"
        Height="820"
        Width="1280"
        MinWidth="1080"
        MinHeight="720"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}" Padding="20">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right"
                            HorizontalAlignment="Right">
                    <TextBlock Text="{Binding AppVersion}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="12"
                               HorizontalAlignment="Right" />
                    <Button Margin="0,10,0,0"
                            Style="{StaticResource LinkButtonStyle}"
                            HorizontalAlignment="Right"
                            Command="{Binding OpenRepositoryCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text=""
                                       FontFamily="Segoe Fluent Icons"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Public repository"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <DockPanel LastChildFill="True">
                    <Border Width="84"
                            Height="84"
                            CornerRadius="20"
                            Background="{DynamicResource AccentMutedBrush}"
                            Margin="0,0,18,0"
                            VerticalAlignment="Center">
                        <Grid Width="52" Height="52" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="{StaticResource StackBaseGeometry}"
                                  Fill="{DynamicResource AccentBrush}"
                                  Stretch="Fill" />
                            <Path Data="{StaticResource StackMidGeometry}"
                                  Fill="{DynamicResource AccentBrush}"
                                  Stretch="Fill"
                                  Opacity="0.82" />
                            <Path Data="{StaticResource StackTopGeometry}"
                                  Fill="{DynamicResource AccentBrush}"
                                  Stretch="Fill"
                                  Opacity="0.64" />
                            <Path Data="{StaticResource StackEyeGeometry}"
                                  Fill="White"
                                  Stretch="Fill" />
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Ollama Model Manager"
                                   FontSize="28"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="14"
                                   Text="List local Ollama models, inspect size and freshness, re-pull them, and delete them safely." />
                    </StackPanel>
                </DockPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,16,0,16"
                Style="{StaticResource PanelBorderStyle}"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Local library" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource MutedTextBrush}" Text="{Binding SummaryText}" />
                    <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource MutedTextBrush}" Text="{Binding SpaceSummaryText}" />
                    <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource MutedTextBrush}" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Grid Grid.Column="1" Margin="18,0,18,0">
                    <TextBox VerticalAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Filter by model name" />
                    <TextBlock Margin="14,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="Search models..."
                               Visibility="{Binding SearchPlaceholderVisibility}" />
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,0"
                                Command="{Binding OpenOllamaFolderCommand}"
                                Content="Open Ollama folder" />
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Width="120"
                                MinWidth="120"
                                Command="{Binding RefreshCommand}"
                                Content="Refresh list" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource PanelBorderStyle}"
                Padding="10">
            <Grid>
                <DataGrid x:Name="ModelsGrid"
                          ItemsSource="{Binding FilteredModels}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                          VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          IsReadOnly="True"
                          Background="{DynamicResource SurfaceBrush}"
                          BorderThickness="0"
                          RowHeaderWidth="0"
                          CanUserSortColumns="True"
                          Sorting="OnDataGridSorting"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          SelectedItem="{Binding SelectedModel}">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource HeaderBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="Padding" Value="12,12" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="12,10" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            <Setter Property="Height" Value="44" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Model"
                                            Binding="{Binding Name}"
                                            SortMemberPath="Name"
                                            ElementStyle="{StaticResource GridTextCellStyle}"
                                            Width="3.7*" />
                        <DataGridTemplateColumn Header="Vision" SortMemberPath="IsVision" Width="84">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                        <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path Data="{StaticResource VisionEyeIconGeometry}"
                                                  Fill="{DynamicResource AccentBrush}"
                                                  Visibility="{Binding IsVision, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </Viewbox>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Size"
                                            Binding="{Binding Size}"
                                            SortMemberPath="SizeSortValue"
                                            ElementStyle="{StaticResource GridTextCellStyle}"
                                            Width="1.2*" />
                        <DataGridTextColumn Header="Updated"
                                            Binding="{Binding Modified}"
                                            SortMemberPath="ModifiedSortValue"
                                            ElementStyle="{StaticResource GridTextCellStyle}"
                                            Width="1.7*" />
                        <DataGridTemplateColumn Header="Actions" Width="126">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource IconButtonStyle}"
                                                Margin="0,0,8,0"
                                                ToolTip="Re-pull model"
                                                Command="{Binding DataContext.RepullModelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text=""
                                                       FontFamily="Segoe Fluent Icons"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Button>
                                        <Button Style="{StaticResource DangerIconButtonStyle}"
                                                ToolTip="Delete model"
                                                Command="{Binding DataContext.DeleteModelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text=""
                                                       FontFamily="Segoe Fluent Icons"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding EmptyStateVisibility}">
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Text="No models to display" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               Text="{Binding EmptyStateText}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
